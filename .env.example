# Copia este archivo a `.env` y rellena los valores.

# Puerto del host donde se publica Leo.
PORT=3000

# Carpeta del host que contiene tus repos. Se monta en /repos dentro del
# contenedor. En cada Proyecto usa repo_path = /repos/<nombre-del-repo>.
REPOS_DIR=/Users/tu-usuario/repositories

# Token de SUSCRIPCIÓN de Claude (NO una API key).
# Genéralo en una máquina con tu suscripción con:  claude setup-token
# (empieza con sk-ant-oat...). También puedes pegarlo desde la UI en Ajustes.
CLAUDE_CODE_OAUTH_TOKEN=
